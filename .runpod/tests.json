{
  "tests": [
    {
      "name": "chat_hello",
      "input": {
        "messages": [
          {
            "role": "user",
            "content": "Say hello in one sentence."
          }
        ],
        "temperature": 0.1,
        "max_tokens": 16
      },
      "timeout": 600000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA RTX A5000",
    "gpuCount": 1,
    "env": [
      {
        "key": "LLM_MODEL",
        "value": "sorc/qwen3.5-instruct:9b"
      },
      {
        "key": "OLLAMA_NUM_CTX",
        "value": "8192"
      },
      {
        "key": "ENABLE_THINKING",
        "value": "false"
      }
    ],
    "allowedCudaVersions": [
      "12.9",
      "12.8",
      "12.7",
      "12.6",
      "12.5",
      "12.4",
      "12.3",
      "12.2"
    ]
  }
}
