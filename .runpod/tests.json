{
  "tests": [
    {
      "name": "chat_hello",
      "input": {
        "messages": [
          {
            "role": "user",
            "content": "Say hello in one sentence."
          }
        ],
        "temperature": 0.1,
        "max_tokens": 64
      },
      "timeout": 3600000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA GeForce RTX 4090",
    "gpuCount": 1,
    "env": [
      {
        "key": "HF_MODEL",
        "value": "Qwen/Qwen3.5-9B"
      },
      {
        "key": "QUANTIZATION",
        "value": "none"
      },
      {
        "key": "MAX_MODEL_LEN",
        "value": "4096"
      },
      {
        "key": "GPU_MEMORY_UTILIZATION",
        "value": "0.85"
      },
      {
        "key": "ENABLE_THINKING",
        "value": "false"
      }
    ],
    "allowedCudaVersions": [
      "12.7",
      "12.6",
      "12.5",
      "12.4",
      "12.3",
      "12.2",
      "12.1",
      "12.0",
      "11.8"
    ]
  }
}
