{
  "title": "Qwen3.5 9B Chat Endpoint",
  "description": "Ollama serverless chat completions for sorc/qwen3.5-instruct:9b (Q8_0, MedScribe-parity). Accepts OpenAI-style messages via RunPod job input. Reasoning disabled by default.",
  "type": "serverless",
  "category": "text",
  "iconUrl": "https://dummyimage.com/100x100/1a1a2e/fff&text=Q",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 35,
    "gpuCount": 1,
    "gpuIds": "ADA_24",
    "allowedCudaVersions": ["12.9", "12.8", "12.7", "12.6", "12.5", "12.4", "12.3", "12.2"],
    "presets": [
      {
        "name": "Default (sorc Q8, 8K context)",
        "defaults": {
          "LLM_MODEL": "sorc/qwen3.5-instruct:9b",
          "DISPLAY_MODEL_NAME": "sorc/qwen3.5-instruct:9b",
          "OLLAMA_NUM_CTX": "8192",
          "DEFAULT_MAX_TOKENS": "4096",
          "MAX_TOKENS_LIMIT": "16384",
          "ENABLE_THINKING": "false"
        }
      },
      {
        "name": "Long context (32K)",
        "defaults": {
          "LLM_MODEL": "sorc/qwen3.5-instruct:9b",
          "DISPLAY_MODEL_NAME": "sorc/qwen3.5-instruct:9b",
          "OLLAMA_NUM_CTX": "32768",
          "DEFAULT_MAX_TOKENS": "4096",
          "MAX_TOKENS_LIMIT": "16384",
          "ENABLE_THINKING": "false"
        }
      }
    ],
    "env": [
      {
        "key": "LLM_MODEL",
        "value": "sorc/qwen3.5-instruct:9b"
      },
      {
        "key": "DISPLAY_MODEL_NAME",
        "value": "sorc/qwen3.5-instruct:9b"
      },
      {
        "key": "OLLAMA_NUM_CTX",
        "input": {
          "name": "Context window",
          "type": "number",
          "description": "Ollama num_ctx — 8192 on 16 GB GPUs, up to 32768 on 24 GB",
          "min": 2048,
          "max": 32768,
          "default": 8192
        }
      },
      {
        "key": "DEFAULT_MAX_TOKENS",
        "input": {
          "name": "Default max tokens",
          "type": "number",
          "description": "Default completion length when request omits max_tokens",
          "min": 1,
          "max": 65536,
          "default": 4096
        }
      },
      {
        "key": "MAX_TOKENS_LIMIT",
        "input": {
          "name": "Max tokens limit",
          "type": "number",
          "description": "Hard cap per request",
          "min": 1,
          "max": 65536,
          "default": 16384,
          "advanced": true
        }
      },
      {
        "key": "ENABLE_THINKING",
        "input": {
          "type": "boolean",
          "name": "Enable thinking",
          "description": "Qwen3.5 chain-of-thought mode (off for instruct/medical use)",
          "default": false,
          "trueValue": "true",
          "falseValue": "false"
        }
      }
    ]
  }
}
